# Copia este archivo como .env.properties y completa los valores
# cp .env.properties.example .env.properties

# Base de datos local (MySQL corriendo en tu máquina)
DB_URL=jdbc:mysql://localhost:3306/meowtfit
DB_USER=root
DB_PASS=

# AWS S3 — dejar en false para guardar comprobantes localmente en uploads/
AWS_S3_ENABLED=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_REGION=us-east-1
AWS_S3_BUCKET=meowtfit-imagenes

# Correo Gmail — necesita una App Password de Google (no la contraseña normal)
MAIL_USERNAME=tu_correo@gmail.com
MAIL_PASSWORD=xxxx_xxxx_xxxx_xxxx

# CORS — dejar así para desarrollo local con Vite
CORS_ORIGINS=http://localhost:5173
